---
import {
  parsePrerequisite,
  buildCourseIndex,
  getCourseLink,
} from '../lib/prerequisites';

interface Props {
  code: string; // e.g. "CS 225", "MATH 257", "CS 598 APE"
}

const { code } = Astro.props;

const parsed = parsePrerequisite(code);
const courseIndex = await buildCourseIndex();
const link = getCourseLink(parsed, courseIndex);
---

{
  link ? (
    link.isInternal ? (
      <a
        href={link.url}
        class="inline-flex items-center gap-0.5 rounded bg-illinois-orange/15 px-1.5 py-0.5 font-mono text-sm text-illinois-orange no-underline hover:bg-illinois-orange/25 transition-colors"
      >
        {code}
      </a>
    ) : (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-0.5 rounded bg-wiki-border/50 px-1.5 py-0.5 font-mono text-sm text-gray-300 no-underline hover:bg-wiki-border hover:text-wiki-text transition-colors"
      >
        {code}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-3 h-3"
        >
          <path
            fill-rule="evenodd"
            d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z"
            clip-rule="evenodd"
          />
          <path
            fill-rule="evenodd"
            d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z"
            clip-rule="evenodd"
          />
        </svg>
      </a>
    )
  ) : (
    <span class="inline-flex items-center rounded bg-wiki-border/50 px-1.5 py-0.5 font-mono text-sm text-wiki-muted">
      {code}
    </span>
  )
}
